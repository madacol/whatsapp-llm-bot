+function writeAll(fd, buffer) {
+  return new Promise((resolve, reject) => {
+    let offset = 0;
+    const writeNext = () => {
+      fs.write(fd, buffer, offset, buffer.length - offset, null, (err, written) => {
+        if (err) {
+          if (err.code === "EAGAIN" || err.code === "EWOULDBLOCK") {
+            setTimeout(writeNext, 10);
+            return;
+          }
+          reject(err);
+          return;
+        }
+        offset += written;
+        if (offset >= buffer.length) {
+          resolve();
+          return;
+        }
+        if (written === 0) {
+          setTimeout(writeNext, 10);
+          return;
+        }
+        writeNext();
+      });
+    };
+    writeNext();
+  });
+}
+function createFdJsonStream(readFd, writeFd, onInputClosed) {
+  const textDecoder = new TextDecoder();
+  const readableStream = new ReadableStream({
+    start(controller) {
+      let content = "";
+      let closed = false;
+      const enqueueLine = (line) => {
+        const trimmedLine = line.trim();
+        if (!trimmedLine) {
+          return;
+        }
+        try {
+          controller.enqueue(JSON.parse(trimmedLine));
+        } catch (err) {
+          console.error("Failed to parse JSON message:", trimmedLine, err);
+        }
+      };
+      const close = () => {
+        if (closed) {
+          return;
+        }
+        closed = true;
+        const tail = textDecoder.decode();
+        if (tail) {
+          content += tail;
+        }
+        enqueueLine(content);
+        onInputClosed?.();
+        controller.close();
+      };
+      const fail = (err) => {
+        if (closed) {
+          return;
+        }
+        closed = true;
+        onInputClosed?.();
+        controller.error(err);
+      };
+      const accept = (chunk) => {
+        content += textDecoder.decode(chunk, { stream: true });
+        const lines = content.split("\n");
+        content = lines.pop() || "";
+        for (const line of lines) {
+          enqueueLine(line);
+        }
+      };
+      const readNext = () => {
+        if (closed) {
+          return;
+        }
+        const buffer = Buffer.alloc(65536);
+        fs.read(readFd, buffer, 0, buffer.length, null, (err, bytesRead) => {
+          if (closed) {
+            return;
+          }
+          if (err) {
+            if (err.code === "EAGAIN" || err.code === "EWOULDBLOCK") {
+              setTimeout(readNext, 10);
+              return;
+            }
+            fail(err);
+            return;
+          }
+          if (bytesRead === 0) {
+            setTimeout(readNext, 10);
+            return;
+          }
+          accept(buffer.subarray(0, bytesRead));
+          readNext();
+        });
+      };
+      readNext();
+    }
+  });
+  const writableStream = new WritableStream({
+    async write(message) {
+      await writeAll(writeFd, Buffer.from(JSON.stringify(message) + "\n", "utf8"));
+    }
+  });
+  return { readable: readableStream, writable: writableStream };
+}
 
