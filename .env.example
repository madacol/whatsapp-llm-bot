# Required
LLM_API_KEY=your-api-key-here
BASE_URL=https://api.openai.com/v1

# Comma-separated WhatsApp sender IDs with master (full) permissions
MASTER_ID=1234567890

# LLM model for chat responses
MODEL=gpt-4.1

# Optional: separate model for media-to-text conversion (images, audio, etc.)
MEDIA_TO_TEXT_MODEL=

# Optional: per-type media-to-text models (override MEDIA_TO_TEXT_MODEL for specific types)
IMAGE_TO_TEXT_MODEL=
AUDIO_TO_TEXT_MODEL=
VIDEO_TO_TEXT_MODEL=

# Optional: model roles (semantic model assignments)
CODING_MODEL=
SMART_MODEL=
FAST_MODEL=

# Optional: override the default system prompt
SYSTEM_PROMPT=

# Optional: Brave Search API key (enables web search action)
BRAVE_API_KEY=

# Optional: Google Gemini API key (enables video generation via Veo 3)
GEMINI_API_KEY=

# Optional: fal.ai API key (enables video generation via fal.ai models)
FAL_KEY=

# Optional: embedding model for memory/recall
EMBEDDING_MODEL=google/gemini-embedding-001

# Optional: image generation model
IMAGE_MODEL=google/gemini-3-pro-image-preview

# Optional: video generation model
VIDEO_MODEL=fal-ai/kling-video/v3/standard

# Optional: memory similarity threshold (0.0 - 1.0, default 0.3)
MEMORY_THRESHOLD=0.3

# Optional: HTML server for rich content
HTML_SERVER_PORT=3100
HTML_SERVER_BASE_URL=

# Optional: SMTP email alerts (e.g. for auth failures)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=
