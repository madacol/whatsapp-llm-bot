# Required
LLM_API_KEY=your-api-key-here
BASE_URL=https://api.openai.com/v1

# Comma-separated WhatsApp sender IDs with master (full) permissions
MASTER_ID=1234567890

# LLM model for chat responses
MODEL=gpt-4.1

# Optional: separate model for media-to-text conversion (images, audio, etc.)
MEDIA_TO_TEXT_MODEL=

# Optional: per-type media-to-text models (override MEDIA_TO_TEXT_MODEL for specific types)
IMAGE_TO_TEXT_MODEL=
AUDIO_TO_TEXT_MODEL=
VIDEO_TO_TEXT_MODEL=

# Optional: model roles (semantic model assignments)
CODING_MODEL=
SMART_MODEL=
FAST_MODEL=

# Optional: override the default system prompt
SYSTEM_PROMPT=

# Optional: Brave Search API key (enables web search action)
BRAVE_API_KEY=

# Optional: Google Gemini API key (enables video generation via Veo 3)
GEMINI_API_KEY=
