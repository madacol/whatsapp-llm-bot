GEMINI_API_KEY=replace-with-your-google-ai-studio-key
GEMINI_MODEL=gemini-3.5-flash
API_TRANSPORT_BASE_URL=http://127.0.0.1:3200
API_TRANSPORT_TOKEN=replace-with-api-transport-token
API_TRANSPORT_ID=voice
API_TRANSPORT_CHAT_ID=api:client-1
API_TRANSPORT_SENDER_ID=user-1
API_TRANSPORT_SENDER_NAME=User
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENAI_API_KEY=replace-with-openai-key
TTS_PROVIDER=openai
TTS_ROUTE=speech
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=marin
TTS_INSTRUCTIONS="Speak clearly and naturally."
TTS_RESPONSE_FORMAT=pcm
TTS_PCM_RATE=24000
TTS_PLAYBACK_DEVICE=default
TTS_OUTPUT_DIR=/tmp/voice-assistant-tts
