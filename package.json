{
    "name": "whatsapp-llm-bot",
    "engines": {
        "node": ">=20.0.0"
    },
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "index.js",
    "scripts": {
        "dev": "node --max-old-space-size=2560 --watch index.js",
        "start": "while node --max-old-space-size=2560 index.js; do sleep 1; done",
        "restart": "kill $(cat .bot.pid)",
        "test": "node --test --experimental-test-isolation=none tests/*.test.js",
        "test:watch": "node --test --experimental-test-isolation=none --watch tests/*.test.js",
        "test:prompts": "node --test tests/*.prompt-test.js",
        "type-check": "npx tsc --noEmit --project jsconfig.json",
        "optimize-prompt": "node scripts/optimize-prompt.js"
    },
    "keywords": [],
    "author": "madacol",
    "dependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.2.76",
        "@electric-sql/pglite": "^0.3.3",
        "@mozilla/readability": "^0.6.0",
        "@resvg/resvg-js": "^2.6.2",
        "@whiskeysockets/baileys": "7.0.0-rc.9",
        "diff": "^8.0.3",
        "dotenv": "^16.5.0",
        "linkedom": "^0.18.12",
        "nodemailer": "^8.0.1",
        "openai": "^4.104.0",
        "shiki": "^4.0.1",
        "turndown": "^7.2.2"
    },
    "devDependencies": {
        "@types/node": "^20.19.0",
        "@types/nodemailer": "^7.0.11",
        "typescript": "^5.8.3"
    }
}
