{
    "name": "whatsapp-llm-bot",
    "engines": {
        "node": ">=20.0.0"
    },
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "index.js",
    "imports": {
        "#harnesses": "./harnesses/index.js",
        "#whatsapp": "./whatsapp/index.js"
    },
    "scripts": {
        "dev": "node --max-old-space-size=2560 --watch index.js",
        "start": "while true; do node --max-old-space-size=2560 index.js; code=$?; echo \"[process-supervisor] node exited with code $code\"; if [ \"$code\" -eq 0 ] || [ \"$code\" -eq 137 ] || [ \"$code\" -eq 143 ]; then sleep 1; else exit \"$code\"; fi; done",
        "restart": "if test -f .bot.pid; then kill -TERM $(cat .bot.pid); else echo 'No .bot.pid found'; fi",
        "test": "node scripts/test-runner.js",
        "test:fast": "node scripts/test-runner.js --fast",
        "test:rendering": "node scripts/test-runner.js --rendering",
        "test:vertical": "node scripts/test-runner.js tests/vertical/*.test.js",
        "test:watch": "node scripts/test-runner.js --watch",
        "test:prompts": "node --test tests/*.prompt-test.js",
        "web:audio": "node clients/web/server.js",
        "type-check": "npx tsc --noEmit --project jsconfig.json",
        "type-check:tests": "tsc --noEmit --project jsconfig.tests.json"
    },
    "keywords": [],
    "author": "madacol",
    "dependencies": {
        "@agentclientprotocol/claude-agent-acp": "0.37.0",
        "@agentclientprotocol/codex-acp": "0.0.44",
        "@earendil-works/pi-coding-agent": "0.75.5",
        "@electric-sql/pglite": "^0.3.3",
        "@mozilla/readability": "^0.6.0",
        "@napi-rs/canvas": "^0.1.100",
        "@picovoice/porcupine-web": "4.0.0",
        "@resvg/resvg-js": "^2.6.2",
        "@whiskeysockets/baileys": "7.0.0-rc13",
        "diff": "^8.0.3",
        "dotenv": "^16.5.0",
        "linkedom": "^0.18.12",
        "mathjax-full": "^3.2.2",
        "nodemailer": "^8.0.1",
        "openai": "^4.104.0",
        "pdfjs-dist": "^4.10.38",
        "pi-acp": "0.0.27",
        "sharp": "^0.34.5",
        "shiki": "^4.0.1",
        "turndown": "^7.2.2"
    },
    "devDependencies": {
        "@types/node": "^20.19.0",
        "@types/nodemailer": "^7.0.11",
        "typescript": "^5.8.3"
    },
    "pnpm": {
        "overrides": {
            "@mariozechner/pi-agent-core": "0.67.3",
            "@mariozechner/pi-ai": "0.67.3",
            "ws": "8.20.1"
        },
        "patchedDependencies": {
            "@agentclientprotocol/codex-acp@0.0.44": "patches/@agentclientprotocol__codex-acp@0.0.44.patch"
        }
    }
}
